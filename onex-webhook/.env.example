# ─────────────────────────────────────────────────────────────────────
#  OneX CRM Webhook Server — Environment Variables
#  Production Ready Configuration
# ─────────────────────────────────────────────────────────────────────
#  Copy this file to `.env` and fill in your actual credentials.
# ─────────────────────────────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=production
BASE_URL=https://api.yourdomain.com

# ── Zoho CRM OAuth2 Credentials ─────────────────────────────────────
# Get these from https://api-console.zoho.in/ (Self Client or Server-based)
ZOHO_REFRESH_TOKEN=your_refresh_token_here
ZOHO_CLIENT_ID=1000.8N2NV1KRHLXAF5ETDAPFDKVDEKY4KG
ZOHO_CLIENT_SECRET=46f324f184d8c34acb60fa50bfb94e00c725284afd

# Zoho region — use these URLs based on your account region:
#   India: accounts.zoho.in / www.zohoapis.in
#   US:    accounts.zoho.com / www.zohoapis.com
#   EU:    accounts.zoho.eu / www.zohoapis.eu
ZOHO_TOKEN_URL=https://accounts.zoho.in/oauth/v2/token
ZOHO_API_URL=https://www.zohoapis.in/crm/v2/Leads

# ── AISensy WhatsApp API ────────────────────────────────────────────
# Get API key from https://app.aisensy.com/
AISENSY_API_KEY=your_api_key_here
AISENSY_CAMPAIGN_NAME=new_lead_welcome_notification
AISENSY_DESTINATION_PHONE=91XXXXXXXXXX
AISENSY_USER_NAME=Your Company Name
# AISENSY_API_URL=https://backend.aisensy.com/campaign/t1/api/v2

# ── Telegram Bot (Optional) ─────────────────────────────────────────
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Email Alerts (Optional) ─────────────────────────────────────────
# Apps Script sends via authenticated Google account
EMAIL_ALERTS=true
ADMIN_EMAIL=your-email@gmail.com

# ── Database ─────────────────────────────────────────────────────────
DB_PATH=./data/leads.db

# ── Retry settings ──────────────────────────────────────────────────
RETRY_MAX_ATTEMPTS=3
RETRY_DELAY_MS=1000

# ── Logging ─────────────────────────────────────────────────────────
LOG_DIR=./logs
